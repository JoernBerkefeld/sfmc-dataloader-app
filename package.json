{
    "name": "sfmc-dataloader-app",
    "version": "0.5.0",
    "description": "Standalone cross-platform desktop app for SFMC Data Extension export/import (wraps sfmc-dataloader)",
    "author": "Joern Berkefeld <joern.berkefeld@gmail.com>",
    "license": "MIT",
    "private": true,
    "type": "commonjs",
    "main": "src/main/main.js",
    "repository": {
        "type": "git",
        "url": "https://github.com/JoernBerkefeld/sfmc-dataloader-app.git"
    },
    "bugs": {
        "url": "https://github.com/JoernBerkefeld/sfmc-dataloader-app/issues"
    },
    "keywords": [
        "sfmc",
        "marketing-cloud",
        "data-extension",
        "electron",
        "desktop",
        "export",
        "import",
        "salesforce"
    ],
    "engines": {
        "node": "^22.13.0 || >=24"
    },
    "scripts": {
        "start": "electron .",
        "dev": "electron .",
        "lint": "eslint .",
        "lint:fix": "eslint --fix .",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "test": "node --test test/*.test.js",
        "dist": "electron-builder --publish never",
        "dist:win": "electron-builder --win --publish never",
        "dist:mac": "electron-builder --mac --publish never",
        "dist:linux": "electron-builder --linux --publish never",
        "update-manifests": "node scripts/update-packaging-manifests.mjs",
        "prepare": "husky || true"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "electron": "^43.0.0",
        "electron-builder": "^26.15.3",
        "eslint": "^10.7.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-jsdoc": "^63.0.12",
        "eslint-plugin-prettier": "^5.5.6",
        "eslint-plugin-unicorn": "^71.1.0",
        "globals": "^17.7.0",
        "husky": "^9.1.7",
        "lint-staged": "^17.0.5",
        "prettier": "^3.9.4"
    },
    "dependencies": {
        "electron-updater": "^6.8.9",
        "sfmc-dataloader": "^2.7.0"
    },
    "lint-staged": {
        "*.{js,mjs,cjs}": [
            "eslint --fix"
        ]
    }
}
